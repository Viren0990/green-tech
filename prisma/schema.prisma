generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactForm {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address    String
  message   String
  createdAt DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  mainImage String   // Primary image for the post
  images    String[] // Array of additional gallery images
  author    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id             String   @id @default(cuid())
  invoiceNo      String   @unique
  date           String
  clientName     String
  clientAddress  String
  clientGstin    String
  placeOfSupply  String
  
  subTotal       Float
  cgstAmount     Float
  sgstAmount     Float
  igstAmount     Float
  roundOff       Float
  finalTotal     Float
  
  taxMode        String
  cgstPercent    Float
  sgstPercent    Float
  igstPercent    Float
  
  items          Json
  
  termsAndConditions String
  amountInWords  String
  bankName       String
  bankAccountNo  String
  bankIfsc       String
  bankBranch     String
  
  createdAt      DateTime @default(now())
}

